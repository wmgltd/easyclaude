# Apple Developer credentials for code signing + notarization.
# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored.

# The exact name of your Developer ID Application certificate as it appears in Keychain.
# Find it via: security find-identity -v -p codesigning
# Should look like: "Developer ID Application: Your Name (ABCDEFGHIJ)"
CSC_NAME="Developer ID Application: Your Name (ABCDEFGHIJ)"

# Your Apple ID email (the one tied to your Developer Program).
APPLE_ID=your-apple-id@example.com

# App-specific password generated at https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
# Must look like: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Apple Team ID (10 alphanumeric chars). Find it at https://developer.apple.com/account → Membership.
APPLE_TEAM_ID=ABCDEFGHIJ
